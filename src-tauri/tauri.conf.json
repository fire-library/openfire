{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "productName": "OpenFire",
  "mainBinaryName": "OpenFire",
  "version": "0.1.5",
  "identifier": "com.openfire.dev",
  "plugins": {
    "deep-link": {
      "mobile": [{ "host": "com.openfire.dev", "pathPrefix": ["/login"] }],
      "desktop": {
        "schemes": ["openfire"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0MkFCMjVEOURDODYyNzUKUldSMVlzaWRYYklxVkhieE10WENvUU5rRGtraW44VHV0WmYvSjZFSU9GQy9DUUZOK0VCaUg1YUwK",
      "endpoints": [
        "https://github.com/fire-library/openfire/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "OpenFire",
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
